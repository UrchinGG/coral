# Coral environment configuration.
# Copy to .env and fill in. Vars marked REQUIRED must be set for production.
# Dev defaults are supplied by docker-compose.override.yml when running `docker compose up`.

# --- Discord ---
DISCORD_TOKEN=                        # REQUIRED: coral-bot token
CORAL_SYNC_DISCORD_TOKEN=             # REQUIRED: coral-sync (account linking + minecraft verify) token

# --- Datastores ---
DATABASE_URL=                         # REQUIRED: postgres://user:pass@host:5432/db
REDIS_URL=                            # REQUIRED: redis://host:6379

# --- Internal auth ---
INTERNAL_API_KEY=                     # REQUIRED: shared secret between coral-api and its clients

# --- Optional integrations ---
HYPIXEL_API_KEY=                      # https://developer.hypixel.net — some endpoints degrade without it

# --- Discord IDs (optional) ---
OWNER_IDS=
HOME_GUILD_ID=
VERIFICATION_ROLE_ID=
BLACKLIST_CHANNEL_ID=
MOD_CHANNEL_ID=
REVIEW_FORUM_ID=
EVIDENCE_FORUM_ID=

# --- Starfish plugin registry (optional) ---
STARFISH_HMAC_SECRET=
STARFISH_ED25519_PRIVATE_KEY=
STARFISH_DISCORD_CLIENT_ID=
STARFISH_DISCORD_CLIENT_SECRET=
STARFISH_GITHUB_TOKEN=
STARFISH_GITHUB_REPO=

# --- Production routing (Traefik) ---
API_DOMAIN=                           # e.g. api.example.com
WEB_DOMAIN=                           # e.g. coral.example.com
SITE_URL=                             # e.g. https://coral.example.com

# --- Build-time auth ---
GIT_AUTH_TOKEN=                       # GitHub PAT for private deps (BuildKit secret); leave blank if unused

# --- Misc ---
RUST_LOG=info
API_PORT=8000
ADMIN_PORT=8080
