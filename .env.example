# Copy to .env and fill in. For local `docker compose up`, the datastores and
# INTERNAL_API_KEY fall back to dev values from docker-compose.override.yml, so
# the two Discord tokens are all you need to bring up a working stack.

# Discord
DISCORD_TOKEN=
CORAL_SYNC_DISCORD_TOKEN=          # second bot: account linking + minecraft verify

# Datastores — required in prod, supplied by the override compose in dev
DATABASE_URL=
REDIS_URL=

# Shared secret between coral-api and its web/bot clients
INTERNAL_API_KEY=

# https://developer.hypixel.net
HYPIXEL_API_KEY=

# Discord IDs
OWNER_IDS=
HOME_GUILD_ID=
VERIFICATION_ROLE_ID=
BLACKLIST_CHANNEL_ID=
MOD_CHANNEL_ID=
REVIEW_FORUM_ID=
EVIDENCE_FORUM_ID=

# Starfish plugin registry
STARFISH_HMAC_SECRET=
STARFISH_ED25519_PRIVATE_KEY=
STARFISH_DISCORD_CLIENT_ID=
STARFISH_DISCORD_CLIENT_SECRET=
STARFISH_GITHUB_TOKEN=
STARFISH_GITHUB_REPO=

# Public URL of the web app
SITE_URL=http://localhost:3000

RUST_LOG=info
API_PORT=8000
ADMIN_PORT=8080
